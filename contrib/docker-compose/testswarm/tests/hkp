#!/bin/bash

SCRIPT_DIR=$(dirname "${BASH_SOURCE[0]}")

for i in $($SCRIPT_DIR/inventory | sort -k2 | awk '/hkp/{print $1 "," $2}'); do
    id=${i#*hkp}; id=${id%_*}; id=${id%-*}
    port=$(docker inspect ${i#*,} | jq -r '.[0].NetworkSettings.Ports."11371/tcp"[0].HostPort')
    echo -n "$id index Alice v1:               "
    curl -SsfL "http://localhost:${port}/pks/lookup?op=index&search=alice@openpgp.example&options=mr" | grep '^uid:'
    echo -n "$id get Alice v1:                 "
    curl -SsfL "http://localhost:${port}/pks/lookup?op=get&search=alice@openpgp.example" | file -
    echo -n "$id index Alice v2:               "
    curl -SsfL "http://localhost:${port}/pks/v2/index/alice@openpgp.example" | grep '"keywords":' | tr -d '\t'
    echo -n "$id get by-identity Alice v2:     "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-identity/alice@openpgp.example" | file -
    echo -n "$id get by-vfingerprint Alice v2: "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-vfingerprint/04eb85bb5fa33a75e15e944e63f231550c4f47e38e" | file -
    echo -n "$id get by-keyid Alice v2:        "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-keyid/f231550c4f47e38e" | file -
    echo
    echo -n "$id index David v1:               "
    curl -SsfL "http://localhost:${port}/pks/lookup?op=index&search=david@openpgp.example&options=mr" | grep '^uid:'
    echo -n "$id get David v1:                 "
    curl -SsfL "http://localhost:${port}/pks/lookup?op=get&search=david@openpgp.example" | file -
    echo -n "$id index David v2:               "
    curl -SsfL "http://localhost:${port}/pks/v2/index/david@openpgp.example" | grep '"keywords":' | tr -d '\t'
    echo -n "$id get by-identity David v2:     "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-identity/david@openpgp.example" | file -
    echo -n "$id get by-vfingerprint David v2: "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-vfingerprint/064199d9eaa6682a78d5a534f62bf76222a54e4debc785dbe6a6c5b34586026fe2" | file -
    echo -n "$id get by-keyid David v2:        "
    curl -SsfL "http://localhost:${port}/pks/v2/certs/by-keyid/4199d9eaa6682a78" | file -
    echo
    echo -n "$id prefixlog:                    "
    echo $(curl -SsfL "http://localhost:${port}/pks/v2/prefixlog/$(date -I)" | sort | tr -cd '0-9a-f\n')
    echo
done
